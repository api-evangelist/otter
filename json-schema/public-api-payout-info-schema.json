{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PayoutInfo",
  "description": "PayoutInfo schema from Public API (Otter Public API).",
  "$id": "https://raw.githubusercontent.com/api-evangelist/otter/refs/heads/main/json-schema/public-api-payout-info-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Payout identifier.",
      "example": "store_123"
    },
    "date": {
      "type": "string",
      "description": "The payout date.",
      "format": "date",
      "example": "2021-10-01"
    }
  },
  "required": [
    "id",
    "date"
  ]
}