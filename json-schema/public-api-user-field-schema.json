{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserField",
  "description": "UserField schema from Public API (Otter Public API).",
  "$id": "https://raw.githubusercontent.com/api-evangelist/otter/refs/heads/main/json-schema/public-api-user-field-schema.json",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "The key of field, this is retrieved from GetEnrollmentConfig API call.",
      "example": "full_name"
    },
    "value": {
      "type": "string",
      "description": "The value of the field.",
      "example": "john doe"
    }
  }
}