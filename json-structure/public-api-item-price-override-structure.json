{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/otter/refs/heads/main/json-structure/public-api-item-price-override-structure.json",
  "name": "ItemPriceOverride",
  "description": "Price override for an item",
  "type": "object",
  "properties": {
    "rules": {
      "type": "array",
      "minItems": 1,
      "description": "Override rules for when this price override should be applied.",
      "items": {
        "$ref": "https://raw.githubusercontent.com/api-evangelist/otter/refs/heads/main/json-schema/public-api-override-rule-schema.json"
      }
    },
    "currencyCode": {
      "maxLength": 3,
      "minLength": 3,
      "type": "string",
      "description": "The 3-letter currency code (ISO 4217) to use for all monetary values.",
      "example": "EUR"
    },
    "amount": {
      "type": "double",
      "description": "Amount the Item costs",
      "example": 25.21
    }
  },
  "required": [
    "amount",
    "currencyCode",
    "rules"
  ]
}