{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/otter/refs/heads/main/json-structure/public-api-store-3-structure.json",
  "name": "Store-3",
  "description": "Store-3 schema from Public API (Otter Public API).",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "nullable": true,
      "description": "The name of the store.",
      "example": "Chipotle"
    },
    "phone": {
      "type": "string",
      "nullable": true,
      "description": "The phone number to contact the store.",
      "example": "+1-555-555-5555"
    }
  }
}