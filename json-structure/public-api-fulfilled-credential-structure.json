{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/otter/refs/heads/main/json-structure/public-api-fulfilled-credential-structure.json",
  "name": "FulfilledCredential",
  "description": "FulfilledCredential schema from Public API (Otter Public API).",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "The key of the credential.",
      "example": "userEmail"
    },
    "value": {
      "type": "string",
      "description": "The value of the credential.",
      "example": "test-user@gmail.com"
    }
  },
  "required": [
    "key",
    "value"
  ]
}