{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/otter/refs/heads/main/json-structure/public-api-user-field-structure.json",
  "name": "UserField",
  "description": "UserField schema from Public API (Otter Public API).",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "The key of field, this is retrieved from GetEnrollmentConfig API call.",
      "example": "full_name"
    },
    "value": {
      "type": "string",
      "description": "The value of the field.",
      "example": "john doe"
    }
  }
}