{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/otter/refs/heads/main/json-structure/public-api-sku-barcode-structure.json",
  "name": "SkuBarcode",
  "description": "A barcode for the product which may be common types like UPC, GTIN, ASIN or an internal type.",
  "type": "object",
  "properties": {
    "barcodeType": {
      "type": "string",
      "description": "The type of the barcode.",
      "enum": [
        "UPC",
        "GTIN",
        "ASIN",
        "INTERNAL"
      ],
      "example": "UPC"
    },
    "value": {
      "type": "string",
      "description": "The value of the barcode.",
      "example": "049000028904 (UPC)"
    }
  }
}