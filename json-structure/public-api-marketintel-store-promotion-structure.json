{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/otter/refs/heads/main/json-structure/public-api-marketintel-store-promotion-structure.json",
  "name": "Marketintel_StorePromotion",
  "description": "The Store Promotion information. At least one of the displayName, promotionType, campaignType or promotionId need to be present.",
  "type": "object",
  "properties": {
    "displayName": {
      "type": "string",
      "nullable": true,
      "description": "The name of the promotion.",
      "example": "Flat rate discount on Christmas day"
    },
    "promotionType": {
      "type": "string",
      "nullable": true,
      "description": "The type of promotion.",
      "example": "Flat rate discount"
    },
    "campaignType": {
      "type": "string",
      "nullable": true,
      "description": "The type of promotion campaign.",
      "example": "Christmas"
    },
    "promotionId": {
      "type": "string",
      "nullable": true,
      "description": "The external promotion id.",
      "example": 12345
    }
  }
}